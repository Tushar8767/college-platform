generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  savedColleges SavedCollege[]
}

model College {
  id                  String   @id @default(cuid())

  name                String
  location            String
  state               String

  fees                Int
  rating              Float

  nirfRank            Int
  cityRank            Int
  stateRank           Int

  placementPercentage Float
  averagePackage      Float

  acceptedExams       String[]
  eligibility         String
  cutoffRank          Int

  description         String
  image               String

  savedBy SavedCollege[]
}

model SavedCollege {
  id        String @id @default(cuid())

  userId    String
  collegeId String

  user    User    @relation(fields: [userId], references: [id])
  college College @relation(fields: [collegeId], references: [id])

  createdAt DateTime @default(now())
}